# AI-COS Environment Configuration
# Copy this file to .env and fill in your values

# ── Provider Keys ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
NVIDIA_API_KEY=nvapi-...

# ── AI-COS Configuration ───────────────────────────────────────
# Database path (default: ~/.aicos/aicos.db)
AICOS_DB_PATH=~/.aicos/aicos.db

# Gateway server
AICOS_GATEWAY_HOST=0.0.0.0
AICOS_GATEWAY_PORT=4000

# Router strategy: auto | cheapest | fastest | best
AICOS_ROUTER_STRATEGY=auto

# Default model override (leave empty for auto-routing)
AICOS_DEFAULT_MODEL=

# ── Cache Settings ─────────────────────────────────────────────
AICOS_CACHE_ENABLED=true
AICOS_CACHE_SIMILARITY_THRESHOLD=0.96
AICOS_CACHE_MAX_SIZE=10000

# ── Memory Settings ────────────────────────────────────────────
AICOS_MEMORY_ENABLED=true
AICOS_MEMORY_MAX_ITEMS=10000
AICOS_MEMORY_INJECTION_LIMIT=5

# ── Context Optimization ───────────────────────────────────────
AICOS_CONTEXT_COMPRESSION_ENABLED=true
AICOS_MAX_CONTEXT_TOKENS=8000
AICOS_LITM_THRESHOLD_TOKENS=6000

# ── Analytics ──────────────────────────────────────────────────
AICOS_ANALYTICS_ENABLED=true

# ── Rate Limiting ──────────────────────────────────────────────
AICOS_RATE_LIMIT_ENABLED=true
AICOS_RATE_LIMIT_RPM=60

# ── Logging ────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
AICOS_LOG_LEVEL=INFO
# Set to true to emit structured JSON logs (recommended for production)
AICOS_LOG_JSON=false

# ── Gateway Auth ───────────────────────────────────────────────
# Master API key — required to create/revoke per-user keys.
# Leave unset for open access (dev/single-user mode).
# AICOS_GATEWAY_API_KEY=your-secret-master-key

# ── CORS ───────────────────────────────────────────────────────
# Default is wildcard (dev-friendly). Restrict for production:
# AICOS_CORS_ALLOWED_ORIGINS=["https://myapp.com","https://api.myapp.com"]

# ── Database ───────────────────────────────────────────────────
# Default: SQLite (WAL mode, suitable for single-server)
# Production (multi-worker): PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/aicos

# ── Secrets directory (Docker Swarm / Compose secrets) ─────────
# Files named like env vars: /run/secrets/OPENAI_API_KEY, etc.
# Leave unset if injecting env vars directly (CI/CD, Kubernetes)
# AICOS_SECRETS_DIR=/run/secrets

# ── Circuit Breaker ────────────────────────────────────────────
# Open after N consecutive failures per provider
AICOS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# Seconds before a half-open probe is attempted
AICOS_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# ── Redis (required for distributed rate limiting) ─────────────
# Without Redis, rate limiting is per-process (not distributed)
# AICOS_REDIS_URL=redis://localhost:6379/0

# ── Database pool (PostgreSQL / PgBouncer) ─────────────────────
# With PgBouncer in transaction mode, set pool_size=2, max_overflow=3.
# Default (5/5) is correct for direct PostgreSQL connections.
# AICOS_DB_POOL_SIZE=5
# AICOS_DB_MAX_OVERFLOW=5

# ── Embeddings ────────────────────────────────────────────────
# Must match the embedding model (384 for all-MiniLM-L6-v2, 512 for hash)
# Used to set the pgvector column dimension in migration 002
# AICOS_EMBEDDING_DIM=384

# ── OpenTelemetry (distributed tracing) ───────────────────────
# Set to OTLP gRPC endpoint to enable spans export (Jaeger, Grafana Tempo, etc.)
# pip install 'aicos[otel]' required
# AICOS_OTEL_ENDPOINT=http://localhost:4317

# ── Sentry (error tracking) ───────────────────────────────────
# Set to Sentry DSN to enable error tracking + performance monitoring
# pip install 'aicos[sentry]' required
# AICOS_SENTRY_DSN=https://...@sentry.io/...

# ── Grafana admin password (docker-compose.prod.yml only) ─────
# GRAFANA_PASSWORD=change-me

# ── Optional: Ollama (local) ───────────────────────────────────
# Set AICOS_OLLAMA_ENABLED=true to route requests to local Ollama
# AICOS_OLLAMA_ENABLED=false
# OLLAMA_BASE_URL=http://localhost:11434
