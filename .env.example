# AI-COS Environment Configuration
# Copy this file to .env and fill in your values

# ── Provider Keys ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
NVIDIA_API_KEY=nvapi-...

# ── AI-COS Configuration ───────────────────────────────────────
# Database path (default: ~/.aicos/aicos.db)
AICOS_DB_PATH=~/.aicos/aicos.db

# Gateway server
AICOS_GATEWAY_HOST=0.0.0.0
AICOS_GATEWAY_PORT=4000

# Router strategy: auto | cheapest | fastest | best
AICOS_ROUTER_STRATEGY=auto

# Default model override (leave empty for auto-routing)
AICOS_DEFAULT_MODEL=

# ── Cache Settings ─────────────────────────────────────────────
AICOS_CACHE_ENABLED=true
AICOS_CACHE_SIMILARITY_THRESHOLD=0.96
AICOS_CACHE_MAX_SIZE=10000

# ── Memory Settings ────────────────────────────────────────────
AICOS_MEMORY_ENABLED=true
AICOS_MEMORY_MAX_ITEMS=10000
AICOS_MEMORY_INJECTION_LIMIT=5

# ── Context Optimization ───────────────────────────────────────
AICOS_CONTEXT_COMPRESSION_ENABLED=true
AICOS_MAX_CONTEXT_TOKENS=8000
AICOS_LITM_THRESHOLD_TOKENS=6000

# ── Analytics ──────────────────────────────────────────────────
AICOS_ANALYTICS_ENABLED=true

# ── Rate Limiting ──────────────────────────────────────────────
AICOS_RATE_LIMIT_ENABLED=true
AICOS_RATE_LIMIT_RPM=60

# ── Optional: Redis Cache ──────────────────────────────────────
# AICOS_REDIS_URL=redis://localhost:6379/0

# ── Optional: Ollama ───────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
